        </mxCell>
        <mxCell id="s3-tcx" value="S3 &#8212; prog-strength-tcx-uploads&#10;original Garmin TCX files (archival)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
