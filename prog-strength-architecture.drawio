<mxfile host="app.diagrams.net" type="device">
  <diagram name="Prog Strength Architecture" id="prog-strength-arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1260" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Prog Strength &#8212; System Architecture" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1614" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Single-EC2 backend &#183; Vercel frontend &#183; MCP integration boundary &#183; autonomous SOW-driven development" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="58" width="1614" height="20" as="geometry" />
        </mxCell>

        <mxCell id="clients-group" value="Clients" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="300" height="395" as="geometry" />
        </mxCell>
        <mxCell id="web" value="Web App&#10;prog-strength-web&#10;Next.js 16 &#183; TypeScript &#183; Tailwind&#10;Deployed on Vercel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="160" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="mobile" value="Mobile App&#10;prog-strength-mobile&#10;React Native &#183; Expo Go (dev)&#10;EAS Build &#8594; TestFlight (beta)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="270" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="clients-note" value="Both clients call the backend via the same public subdomains over HTTPS.&#10;No client-side persistence &#8212; all state lives in the API." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="70" y="395" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ec2-group" value="Production EC2 (t4g.small &#183; ARM64 &#183; us-east-2) &#8212; single host, all services co-located, fronted by Caddy" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8f0;strokeColor=#d79b00;dashed=0;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#b46504;" vertex="1" parent="1">
          <mxGeometry x="380" y="110" width="720" height="740" as="geometry" />
        </mxCell>

        <mxCell id="caddy" value="Caddy &#8212; TLS termination + reverse proxy (Let's Encrypt)&#10;api.progstrength.fitness &#8594; api:8080  &#183;  mcp.progstrength.fitness &#8594; mcp:8000&#10;agent.progstrength.fitness &#8594; agent:8001  &#183;  monitoring.progstrength.fitness &#8594; grafana:3000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="150" width="680" height="80" as="geometry" />
        </mxCell>

        <mxCell id="app-group" value="Application Services (Docker Compose &#183; shared docker network)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;dashed=1;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#5e8e3e;" vertex="1" parent="1">
          <mxGeometry x="400" y="250" width="680" height="285" as="geometry" />
        </mxCell>
        <mxCell id="agent" value="Agent Service &#183; prog-strength-agent&#10;FastAPI &#8212; stateless /chat, persistent MCP session opened at startup&#10;Tiered Claude routing: Haiku 4.5 router &#8594; Haiku 4.5 / Sonnet 4.6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="285" width="640" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mcp" value="MCP Server &#183; prog-strength-mcp&#10;Python &#183; FastMCP &#8212; exposes tools to the agent&#10;Never touches the DB; proxies all calls to the Go API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="365" width="640" height="70" as="geometry" />
        </mxCell>
        <mxCell id="api" value="Go API &#183; prog-strength-api&#10;Go / Chi &#8212; auth, workouts, exercises, bodyweight, TCX ingest, derived metrics&#10;SOLE reader/writer of the application + telemetry DBs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="445" width="640" height="80" as="geometry" />
        </mxCell>

