        </mxCell>
        <mxCell id="s3-tfstate" value="S3 &#8212; prog-strength-terraform-backend&#10;Terraform state files (IaC backend)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1170" y="525" width="200" height="85" as="geometry" />
        </mxCell>
        <mxCell id="cw-logs" value="CloudWatch Logs&#10;/aws/logs/prog-strength-api&#10;/aws/ec2/prog-strength-developer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1390" y="525" width="200" height="85" as="geometry" />
        </mxCell>
        <mxCell id="terraform" value="Terraform &#183; prog-strength-infra (IaC)&#10;Provisions prod EC2, developer launch template, S3, IAM, CloudWatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1170" y="635" width="420" height="65" as="geometry" />
        </mxCell>
        <mxCell id="aws-note" value="Terraform state lives in the prog-strength-terraform-backend bucket; plan/apply runs through GitHub Actions per repo." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#7a6720;" vertex="1" parent="1">
          <mxGeometry x="1170" y="715" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="aws-novelty" value="Cost philosophy: SQLite + Litestream replaces an RDS instance; one EC2 hosts every service; CloudWatch + Grafana are the only managed pieces." style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#7a6720;" vertex="1" parent="1">
          <mxGeometry x="1170" y="760" width="420" height="60" as="geometry" />
        </mxCell>

        <mxCell id="auto-group" value="Autonomous Development Pipeline &#8212; prog-strength-developer (ephemeral worker, manually dispatched per SOW)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#888888;dashed=0;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="40" y="890" width="1580" height="330" as="geometry" />
        </mxCell>

        <mxCell id="auto-docs" value="prog-strength-docs&#10;SOWs + plans&#10;(YAML frontmatter: status, repos[])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="950" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="auto-gha" value="GitHub Actions&#10;dispatch-sow.yml&#10;(manual workflow_dispatch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="950" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="auto-worker" value="Ephemeral EC2 Worker&#10;Amazon Linux 2023 &#183; ARM64&#10;Provisioned from Terraform launch template" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8f0;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="590" y="950" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="auto-claude" value="Claude Code (non-interactive)&#10;Clones repos listed in SOW frontmatter&#10;Runs SOW &#183; commits feat/&lt;slug&gt; branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="870" y="950" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="auto-prs" value="Pull Requests&#10;opened against each affected repo&#10;(gh CLI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1150" y="950" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="auto-term" value="Self-terminate&#10;+ stream logs to CloudWatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1410" y="950" width="180" height="100" as="geometry" />
        </mxCell>

        <mxCell id="auto-note" value="Novelty: cross-repo feature delivery without writing code by hand. A human writes a SOW (in prog-strength-docs) &#8594; reviews &#183; merges &#8594; dispatches via Actions &#8594; reviews resulting PRs &#8594; merges." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="70" y="1080" width="1520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="auto-footer-box" value="The owner is the gate: dispatch is manual (no auto-discovery), concurrency is serialized to one worker at a time, and every resulting PR is human-reviewed before merge. Same Anthropic Claude API that powers the agent service powers the developer worker &#8212; the platform builds on itself." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffaf0;strokeColor=#d79b00;fontSize=11;fontColor=#7a4a00;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="70" y="1125" width="1520" height="75" as="geometry" />
        </mxCell>

