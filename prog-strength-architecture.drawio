          <mxGeometry x="435" y="585" width="290" height="65" as="geometry" />
        </mxCell>
        <mxCell id="db-telem" value="SQLite &#8212; Telemetry DB&#10;separate read/write path &#183; usage + /metrics aggregations" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="755" y="585" width="290" height="65" as="geometry" />
        </mxCell>

        <mxCell id="mon-group" value="Monitoring Stack &#8212; self-hosted, low-cost" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;dashed=1;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#3b6299;" vertex="1" parent="1">
